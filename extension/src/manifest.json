{
  "manifest_version": 3,
  "name": "PhoneBrowserUse",
  "version": "2.0.0",
  "description": "Browse the web with a phone call.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"]
}
