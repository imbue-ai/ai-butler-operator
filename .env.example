# Anthropic API key for browser-use agent + page descriptions
ANTHROPIC_API_KEY=sk-ant-...

# Phone number displayed to users (your VAPI number)
VAPI_PHONE_NUMBER=+1234567890

# VAPI setup (for setup_vapi_tools.py)
VAPI_API_KEY=your-vapi-api-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_SERVER_URL=https://your-ngrok-url.ngrok-free.dev

# Server host/port
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated, or * for dev)
CORS_ORIGINS=*

# Session config (optional)
# CODE_EXPIRY_MINUTES=10
# SESSION_TIMEOUT_MINUTES=30
# SCREENSHOT_FPS=1.5
